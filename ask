#!/bin/bash

# ask - Simple OpenRouter API CLI tool
# Usage: ask [OPTIONS] [PROMPT]

set -euo pipefail

ASK_UPDATE_URL="https://raw.githubusercontent.com/vicyap/ask/main/ask"

ask_update() {
    local target target_dir
    target_dir="$(cd "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
    target="$target_dir/$(basename -- "${BASH_SOURCE[0]}")"

    if git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Refusing to overwrite $target — it is inside a git working tree." >&2
        echo "Run 'git pull' from $target_dir instead." >&2
        exit 1
    fi

    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile:-}"' EXIT

    echo "Fetching latest ask from $ASK_UPDATE_URL..." >&2
    if ! curl -fsSL "$ASK_UPDATE_URL" -o "$tmpfile"; then
        echo "Error: download failed" >&2
        exit 1
    fi

    if ! head -n1 "$tmpfile" | grep -qE '^#!.*\b(bash|sh)\b'; then
        echo "Error: downloaded file does not look like a shell script" >&2
        exit 1
    fi

    if cmp -s "$tmpfile" "$target"; then
        echo "ask is already up to date." >&2
        exit 0
    fi

    chmod +x "$tmpfile"
    if ! mv -f "$tmpfile" "$target" 2>/dev/null; then
        echo "Error: cannot write to $target (permission denied?)" >&2
        echo "Try: sudo $target -u" >&2
        exit 1
    fi

    echo "✓ ask updated at $target" >&2
}

# Model shortcuts function
get_model() {
    case "$1" in
        c) echo "inception/mercury-2:nitro" ;;
        g) echo "google/gemini-3-flash-preview:nitro" ;;
        s) echo "anthropic/claude-sonnet-4.6:nitro" ;;
        x) echo "x-ai/grok-4.1-fast:nitro" ;;
        d) echo "deepseek/deepseek-v4-flash:nitro" ;;
        q) echo "qwen/qwen3.5-397b-a17b:nitro" ;;
        o) echo "openai/gpt-5.5:nitro" ;;
        opus) echo "anthropic/claude-opus-4.7:nitro" ;;
        codex) echo "openai/gpt-5.3-codex:nitro" ;;
    esac
}

# Default values
MODEL="anthropic/claude-sonnet-4.6:nitro"
SYSTEM_PROMPT=""
PROMPT=""
STREAMING=false
NO_SYSTEM=false
PROVIDER_ORDER=""
QUIET=false
JSON_OUTPUT=false
FILE_CONTEXTS=()

# Default system prompt (direct answers)
DEFAULT_PROMPT="You are a direct answer engine. Output ONLY the requested information.

For commands: Output executable syntax only. No explanations, no comments.
For questions: Output the answer only. No context, no elaboration.

Rules:
- If asked for a command, provide ONLY the command
- If asked a question, provide ONLY the answer
- Never include markdown formatting or code blocks
- Never add explanatory text before or after
- Assume output will be piped or executed directly
- For multi-step commands, use && or ; to chain them
- Make commands robust and handle edge cases silently"

# Function to show help
show_help() {
    cat << 'EOF'
ask - Query AI models via the OpenRouter API.

ask sends a prompt to an AI model and prints the response to stdout. It is
optimized for short, direct answers: commands, code snippets, and facts.
By default a system prompt instructs the model to return only the requested
information with no markdown, no commentary, and no code fences.

Usage:
  ask [OPTIONS] [PROMPT]
  echo "text" | ask [OPTIONS]
  echo "text" | ask [OPTIONS] "additional instructions"

When no PROMPT argument is given, ask reads from stdin. When both stdin and
a PROMPT argument are provided, stdin content is prepended to the prompt.

Model selection:
  -s            Claude Sonnet 4.6 (default) - strong reasoning
  -o            GPT-5.5 - latest OpenAI flagship
  -opus         Claude Opus 4.7 - strongest Anthropic model
  -codex        GPT-5.3 Codex - optimized for code generation
  -c            Mercury 2 - fast reasoning diffusion
  -g            Gemini 3 Flash Preview - fast, general purpose
  -x            Grok 4.1 Fast - xAI agentic tool calling
  -d            DeepSeek V4 Flash - efficient MoE reasoning
  -q            Qwen3.5 397B - large open vision-language MoE
  -m MODEL      Any OpenRouter model ID (e.g. openai/gpt-5.5)

File context:
  -f FILE       Include file contents in the prompt. Repeatable.
                Files are prepended with a header showing the path.

Output control:
  --stream      Stream response tokens as they arrive
  --json        Print the raw JSON API response instead of extracted text
  -Q            Quiet mode - suppress the metadata footer on stderr

Prompt control:
  --system MSG  Set a custom system prompt
  -r            Disable the system prompt entirely (raw model behavior)

Provider routing:
  --provider P  Comma-separated provider order for fallback routing

Other:
  -h, --help    Show this help message
  -u, --update  Update ask in place by downloading the latest version
                from https://github.com/vicyap/ask

Behavior:
  The metadata footer (model name, provider, latency, tokens/sec) is printed
  to stderr so it does not interfere with piped output. Use -Q to suppress it.
  Errors are also printed to stderr and cause a non-zero exit code.

Examples:
  # Get a command
  ask ffmpeg command to convert mp4 to gif

  # Use a specific model
  ask -o "explain this error" < error.log

  # Include files for context
  ask -f src/main.py -f src/utils.py "find the bug in main.py"

  # Pipe input
  git diff | ask "review this diff for issues"
  cat script.py | ask "add error handling"

  # Chain with other tools
  ask "list all .env keys used in this project" | sort

  # Custom system prompt
  ask --system "You are a security auditor" -f app.py "audit this"

  # Raw model output (no system prompt)
  ask -r "write a haiku about bash"

  # Streaming for long responses
  ask --stream -opus "explain the Linux boot process"

  # Get raw JSON response for scripting
  ask --json "what is 2+2" | jq '.usage'

  # Quiet mode (no metadata footer)
  ask -Q "capital of france"
EOF
    exit 0
}

# Parse command line arguments
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help) show_help ;;
        -u|--update) ask_update; exit 0 ;;
        -opus|-codex)
            MODEL="$(get_model "${1:1}")"
            shift ;;
        -[cgsdqxo])
            MODEL="$(get_model "${1:1}")"
            shift ;;
        -m)
            MODEL="${2:?Error: -m requires a model name}"
            shift 2 ;;
        -r)
            NO_SYSTEM=true
            shift ;;
        -f)
            FILE_CONTEXTS+=("${2:?Error: -f requires a file path}")
            shift 2 ;;
        -Q)
            QUIET=true
            shift ;;
        --stream)
            STREAMING=true
            shift ;;
        --json)
            JSON_OUTPUT=true
            shift ;;
        --system)
            SYSTEM_PROMPT="${2:?Error: --system requires a prompt}"
            shift 2 ;;
        --provider)
            PROVIDER_ORDER="${2:?Error: --provider requires providers}"
            shift 2 ;;
        *)
            PROMPT="$*"
            break ;;
    esac
done

# Check for API key (after parsing so -u/--update can short-circuit without one)
if [ -z "${OPENROUTER_API_KEY:-}" ]; then
    echo "Error: OPENROUTER_API_KEY environment variable is not set" >&2
    exit 1
fi

# If no prompt provided as argument, read from stdin
if [ -z "$PROMPT" ]; then
    if [ -t 0 ]; then
        echo "Error: No prompt provided. Use 'ask -h' for help." >&2
        exit 1
    fi
    # Read all stdin, preserving multi-line format
    PROMPT=$(cat)
fi

# Prepend file contents to prompt
if [ ${#FILE_CONTEXTS[@]} -gt 0 ]; then
    FILE_CONTENT=""
    for file in "${FILE_CONTEXTS[@]}"; do
        if [ ! -f "$file" ]; then
            echo "Error: File not found: $file" >&2
            exit 1
        fi
        FILE_CONTENT+="--- FILE: $file ---
$(cat "$file")

"
    done
    PROMPT="${FILE_CONTENT}${PROMPT}"
fi

# Apply default system prompt unless disabled or custom prompt provided
if [ "$NO_SYSTEM" = false ] && [ -z "$SYSTEM_PROMPT" ]; then
    SYSTEM_PROMPT="$DEFAULT_PROMPT"
fi

# Build messages array with proper JSON escaping
if [ -n "$SYSTEM_PROMPT" ]; then
    MESSAGES='[{"role":"system","content":'"$(printf '%s' "$SYSTEM_PROMPT" | jq -Rs .)"'},{"role":"user","content":'"$(printf '%s' "$PROMPT" | jq -Rs .)"'}]'
else
    MESSAGES='[{"role":"user","content":'"$(printf '%s' "$PROMPT" | jq -Rs .)"'}]'
fi

# Record start time
START_TIME=$(date +%s.%N)

# Build JSON payload once
PROVIDER_JSON=""
if [ -n "$PROVIDER_ORDER" ]; then
    PROVIDER_JSON=',"provider":{"order":['$(echo "$PROVIDER_ORDER" | awk -F, '{for(i=1;i<=NF;i++) printf "\"%s\"%s", $i, (i<NF?",":"")}')']}'
fi

JSON_PAYLOAD='{
    "model": "'"$MODEL"'",
    "messages": '"$MESSAGES"',
    "stream": '$([ "$STREAMING" = true ] && echo true || echo false)"$PROVIDER_JSON"'
}'

API_URL="https://openrouter.ai/api/v1/chat/completions"

# Add newline before answer
echo

# Make API request
if [ "$STREAMING" = true ]; then
    # Streaming mode
    curl -sS "$API_URL" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $OPENROUTER_API_KEY" \
      -d "$JSON_PAYLOAD" 2>&1 | while IFS= read -r line; do
        # Check for errors
        if echo "$line" | grep -q '"error"'; then
            echo "Error: $(echo "$line" | jq -r '.error.message // .error // "Unknown error"')" >&2
            exit 1
        fi

        # Process SSE data lines
        if [[ "$line" == data:* ]]; then
            json="${line#data: }"
            [ "$json" = "" ] || [ "$json" = "[DONE]" ] && continue

            content=$(echo "$json" | jq -r '.choices[0].delta.content // ""' 2>/dev/null)
            [ -n "$content" ] && printf '%s' "$content"
        fi
    done
    echo

    # Show metadata
    if [ "$QUIET" = false ]; then
        ELAPSED=$(printf "%.2f" $(echo "$(date +%s.%N) - $START_TIME" | bc))
        echo
        echo "[$MODEL - ${ELAPSED}s]" >&2
    fi
else
    # Non-streaming mode
    response=$(curl -sS "$API_URL" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $OPENROUTER_API_KEY" \
      -d "$JSON_PAYLOAD" 2>&1)

    # Check for errors
    if echo "$response" | grep -q '"error"'; then
        echo "Error: $(echo "$response" | jq -r '.error.message // .error // "Unknown error"')" >&2
        exit 1
    fi

    if [ "$JSON_OUTPUT" = true ]; then
        # Raw JSON output
        echo "$response" | jq .
    else
        # Extract and print content
        echo "$response" | jq -r '.choices[0].message.content // "No response received"'
    fi

    # Show metadata
    if [ "$QUIET" = false ]; then
        ELAPSED=$(printf "%.2f" $(echo "$(date +%s.%N) - $START_TIME" | bc))
        TOKENS=$(echo "$response" | jq -r '.usage.completion_tokens // 0')
        PROVIDER=$(echo "$response" | jq -r '.provider // "Unknown"')
        TPS=$(echo "scale=1; $TOKENS / $ELAPSED" | bc 2>/dev/null || echo "0.0")

        echo
        echo "[$MODEL via $PROVIDER - ${ELAPSED}s - ${TPS} tok/s]" >&2
    fi
fi
